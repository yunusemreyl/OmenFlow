<Application
    x:Class="OmenFlow_App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmenFlow_App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Themes/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <Style x:Key="ShadowCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource OmenCardBackgroundBaseBrush}"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="24"/>
                <Setter Property="BorderBrush" Value="{ThemeResource OmenCardBorderBaseBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="12"/>
            </Style>

            <Style x:Key="GridBoxStyle" TargetType="ToggleButton">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="Margin" Value="4"/>
            </Style>

            <Style x:Key="HorizontalBarBoxStyle" TargetType="ToggleButton">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Padding" Value="16,0,16,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style x:Key="MiniCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource OmenCardBackgroundBaseBrush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="BorderBrush" Value="{ThemeResource OmenCardBorderBaseBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="0,8,0,0"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
