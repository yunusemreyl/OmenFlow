<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="OmenFlow_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OmenFlow_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="OmenFlow.App"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="OmenFlow"
            Height="32"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="False">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsPaneOpen="False"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.Resources>
                <x:Double x:Key="NavigationViewTopPaneHeight">36</x:Double>
                <x:Double x:Key="NavigationViewItemContentHeight">32</x:Double>
                <Thickness x:Key="NavigationViewItemContentMargin">8,0,8,0</Thickness>
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Performans"
                    IsSelected="True"
                    Tag="performance">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Graphics Switcher" Tag="graphics_switcher">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F4;" FontSize="14" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Klavye" Tag="lighting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE765;" FontSize="14" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Grid Margin="12,4,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <InfoBar x:Name="BackendConnectionInfoBar" Grid.Row="0" IsOpen="False" Severity="Error" Title="Bağlantı Hatası" Message="Arka plan servisi (OmenFlow.Worker) ile bağlantı kurulamadı. Yeniden bağlanılıyor..." IsClosable="False" Margin="16,8,16,0" />
                <Border Grid.Row="1"
                        Background="{ThemeResource OmenCardBackgroundDarkBrush}" 
                        BorderBrush="{ThemeResource OmenCardBorderDarkBrush}" 
                        BorderThickness="1" 
                        CornerRadius="10">
                    <Frame x:Name="NavFrame" />
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
