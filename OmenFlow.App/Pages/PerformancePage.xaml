<Page
    x:Class="OmenFlow_App.Pages.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    

    <Grid Background="{ThemeResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Performans Kontrolü" FontSize="28" FontWeight="SemiBold" Margin="36,24,0,16" Foreground="{ThemeResource PrimaryTextBrush}"/>

        <ScrollViewer Grid.Row="1" Margin="24,0,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- BÖLÜM 1: Sistem Durumu -->
                <TextBlock Text="Sistem Durumu" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TertiaryTextBrush}" Margin="12,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- İşlemci (CPU) Kartı -->
                    <Border Grid.Column="0" Style="{StaticResource ShadowCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <FontIcon Glyph="&#xE7A6;" FontSize="20" Foreground="#2563EB" Margin="0,0,8,0"/>
                                <TextBlock Text="İşlemci (CPU)" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Sahte Çizgi Grafik Alanı -->
                            <Border Height="80" Background="{ThemeResource CardAltBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16">
                                <TextBlock Text="[Grafik Alanı]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D1D5DB"/>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE7A3;" FontSize="12" Foreground="#DC2626" Margin="0,0,4,0"/>
                                        <TextBlock Text="Sıcaklık" FontSize="12" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CpuTempText" Text="45°C" FontSize="22" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE945;" FontSize="12" Foreground="#D97706" Margin="0,0,4,0"/>
                                        <TextBlock Text="Güç (Watt)" FontSize="12" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CpuPowerText" Text="15.2 W" FontSize="22" FontWeight="Bold" Foreground="#D97706" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="#10B981" Margin="0,0,4,0"/>
                                        <TextBlock Text="Kullanım" FontSize="12" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CpuUsageText" Text="%12" FontSize="22" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Ekran Kartı (GPU) Kartı -->
                    <Border Grid.Column="1" Style="{StaticResource ShadowCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <FontIcon Glyph="&#xE7A6;" FontSize="20" Foreground="#10B981" Margin="0,0,8,0"/>
                                <TextBlock Text="Ekran Kartı (GPU)" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Sahte Çizgi Grafik Alanı -->
                            <Border Height="80" Background="{ThemeResource CardAltBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16">
                                <TextBlock Text="[Grafik Alanı]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D1D5DB"/>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE7A3;" FontSize="12" Foreground="#DC2626" Margin="0,0,4,0"/>
                                        <TextBlock Text="Sıcaklık" FontSize="12" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="GpuTempText" Text="38°C" FontSize="22" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE945;" FontSize="12" Foreground="#D97706" Margin="0,0,4,0"/>
                                        <TextBlock Text="Güç (Watt)" FontSize="12" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="GpuPowerText" Text="8.4 W" FontSize="22" FontWeight="Bold" Foreground="#D97706" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE9D9;" FontSize="12" Foreground="#10B981" Margin="0,0,4,0"/>
                                        <TextBlock Text="Kullanım" FontSize="12" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="GpuUsageText" Text="%4" FontSize="22" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- BÖLÜM 2: Soğutma ve Fanlar -->
                <TextBlock Text="Soğutma ve Fanlar" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TertiaryTextBrush}" Margin="12,16,0,8"/>
                <Border Style="{StaticResource ShadowCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="CPU Fan Hızı:" FontSize="16" Foreground="{ThemeResource TertiaryTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="CpuFanText" Text="2400 RPM" FontSize="22" FontWeight="Bold" Foreground="{ThemeResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <!-- Sahte Kadran -->
                            <FontIcon Glyph="&#xE9CA;" FontSize="32" Foreground="#2563EB" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="GPU Fan Hızı:" FontSize="16" Foreground="{ThemeResource TertiaryTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="GpuFanText" Text="0 RPM" FontSize="22" FontWeight="Bold" Foreground="{ThemeResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <!-- Sahte Kadran -->
                            <FontIcon Glyph="&#xE9CA;" FontSize="32" Foreground="#10B981" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- BÖLÜM 3: Kontrol Paneli (4 Sütunlu Yerleşim) -->
                <TextBlock Text="Kontrol Paneli" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TertiaryTextBrush}" Margin="12,16,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 1. Performans Profili -->
                    <Border Grid.Column="0" Style="{StaticResource ShadowCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Performans Profili" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" Margin="0,0,0,16"/>
                            <!-- List View like the image -->
                            <StackPanel>
                                <ToggleButton x:Name="BtnPerfQuiet" Style="{StaticResource HorizontalBarBoxStyle}" Click="PerfMode_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE7ED;" Foreground="#10B981" Margin="0,0,12,0"/>
                                        <TextBlock Text="Düşük Gürültü" VerticalAlignment="Center" FontWeight="Medium"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnPerfDefault" Style="{StaticResource HorizontalBarBoxStyle}" IsChecked="True" Click="PerfMode_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE799;" Foreground="#2563EB" Margin="0,0,12,0"/>
                                        <TextBlock Text="Dengeli (Standart)" VerticalAlignment="Center" FontWeight="Medium"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnPerfPerf" Style="{StaticResource HorizontalBarBoxStyle}" Click="PerfMode_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE945;" Foreground="#DC2626" Margin="0,0,12,0"/>
                                        <TextBlock Text="Maksimum Performans" VerticalAlignment="Center" FontWeight="Medium"/>
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 2. Fan Modu (2x2 Grid) -->
                    <Border Grid.Column="1" Style="{StaticResource ShadowCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Fan Profili" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" Margin="0,0,0,16"/>
                            <Grid Height="160">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ToggleButton x:Name="BtnFanAuto" Grid.Row="0" Grid.Column="0" Style="{StaticResource GridBoxStyle}" IsChecked="True" Click="FanMode_Click">
                                    <StackPanel VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE9A1;" FontSize="24" Foreground="#2563EB" Margin="0,0,0,8"/>
                                        <TextBlock Text="Auto BIOS" HorizontalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </ToggleButton>

                                <ToggleButton x:Name="BtnFanOmenFlow" Grid.Row="0" Grid.Column="1" Style="{StaticResource GridBoxStyle}" Click="FanMode_Click">
                                    <StackPanel VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE81E;" FontSize="24" Foreground="#10B981" Margin="0,0,0,8"/>
                                        <TextBlock Text="OmenFlow" HorizontalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </ToggleButton>

                                <ToggleButton x:Name="BtnFanMax" Grid.Row="1" Grid.Column="0" Style="{StaticResource GridBoxStyle}" Click="FanMode_Click">
                                    <StackPanel VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE9CA;" FontSize="24" Foreground="#D97706" Margin="0,0,0,8"/>
                                        <TextBlock Text="Max" HorizontalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </ToggleButton>

                                <ToggleButton x:Name="BtnFanManual" Grid.Row="1" Grid.Column="1" Style="{StaticResource GridBoxStyle}" Click="FanMode_Click">
                                    <StackPanel VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE790;" FontSize="24" Foreground="{ThemeResource TertiaryTextBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Custom" HorizontalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </ToggleButton>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 3. GPU MUX Anahtarı -->
                    <Border Grid.Column="2" Style="{StaticResource ShadowCardStyle}">
                        <StackPanel>
                            <TextBlock Text="GPU MUX Anahtarı" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" Margin="0,0,0,16"/>
                            <!-- Şematik Görünüm -->
                            <Grid Height="160">
                                <StackPanel VerticalAlignment="Center">
                                    <ToggleButton x:Name="BtnMuxHybrid" Style="{StaticResource HorizontalBarBoxStyle}" IsChecked="True" Click="MuxMode_Click" Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal">
                                            <FontIcon Glyph="&#xE9D9;" Foreground="#10B981" Margin="0,0,12,0"/>
                                            <TextBlock Text="Hybrid" VerticalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    
                                    <ToggleButton x:Name="BtnMuxDiscrete" Style="{StaticResource HorizontalBarBoxStyle}" Click="MuxMode_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <FontIcon Glyph="&#xE7F4;" Foreground="#DC2626" Margin="0,0,12,0"/>
                                            <TextBlock Text="Sadece dGPU" VerticalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 4. GPU TGP Güç Limiti -->
                    <Border Grid.Column="3" Style="{StaticResource ShadowCardStyle}">
                        <StackPanel>
                            <TextBlock Text="GPU TGP Güç Limiti" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" Margin="0,0,0,16"/>
                            <!-- Çizgili barlar -->
                            <Grid Height="160">
                                <StackPanel VerticalAlignment="Center">
                                    <ToggleButton x:Name="BtnGpuBase" Style="{StaticResource HorizontalBarBoxStyle}" Click="GpuPower_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Temel TGP" VerticalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    
                                    <ToggleButton x:Name="BtnGpuExtra" Style="{StaticResource HorizontalBarBoxStyle}" IsChecked="True" Click="GpuPower_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Ara Limit" VerticalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </ToggleButton>

                                    <ToggleButton x:Name="BtnGpuMax" Style="{StaticResource HorizontalBarBoxStyle}" Click="GpuPower_Click" Margin="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Tam TGP" VerticalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                </Grid>

                <!-- Özel Fan Eğrisi Alanı -->
                <Border x:Name="CustomFanCurveContainer" Style="{StaticResource ShadowCardStyle}" Visibility="Collapsed" Margin="12,16,12,12">
                    <StackPanel>
                        <TextBlock Text="Özel Fan Eğrisi Ayarları" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="Noktaları sürükleyerek sıcaklık-hız eğrisini belirleyin. (Dikey: % Fan Hızı, Yatay: °C Sıcaklık)" FontSize="12" Foreground="{ThemeResource TertiaryTextBrush}" Margin="0,0,0,16"/>
                        
                        <Border Background="{ThemeResource CardAltBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" HorizontalAlignment="Center">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Y Axis Labels (Fan Hızı %) -->
                                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,12,0" Width="30">
                                    <TextBlock Text="100%" VerticalAlignment="Top" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}" Margin="0,-8,0,0" HorizontalAlignment="Right"/>
                                    <TextBlock Text="75%" VerticalAlignment="Top" Margin="0,42,0,0" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="50%" VerticalAlignment="Center" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="25%" VerticalAlignment="Bottom" Margin="0,0,0,42" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="0%" VerticalAlignment="Bottom" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}" Margin="0,0,0,-8" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- X Axis Labels (Sıcaklık °C) -->
                                <Grid Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Height="20">
                                    <TextBlock Text="0°C" HorizontalAlignment="Left" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}" Margin="-8,0,0,0"/>
                                    <TextBlock Text="25°C" HorizontalAlignment="Left" Margin="190,0,0,0" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    <TextBlock Text="50°C" HorizontalAlignment="Center" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    <TextBlock Text="75°C" HorizontalAlignment="Right" Margin="0,0,190,0" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                    <TextBlock Text="100°C" HorizontalAlignment="Right" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}" Margin="0,0,-12,0"/>
                                </Grid>

                                <Canvas x:Name="FanCurveCanvas" Grid.Row="0" Grid.Column="1" Height="200" Width="800" HorizontalAlignment="Left" Background="Transparent" 
                                        PointerMoved="FanCurveCanvas_PointerMoved" PointerReleased="FanCurveCanvas_PointerReleased" PointerCanceled="FanCurveCanvas_PointerReleased">
                                    
                                    <!-- Background Grid Lines -->
                                    <Line X1="0" Y1="50" X2="800" Y2="50" Stroke="{ThemeResource CardBorderBrush}" StrokeThickness="1" StrokeDashArray="2,2"/>
                                    <Line X1="0" Y1="100" X2="800" Y2="100" Stroke="{ThemeResource CardBorderBrush}" StrokeThickness="1" StrokeDashArray="2,2"/>
                                    <Line X1="0" Y1="150" X2="800" Y2="150" Stroke="{ThemeResource CardBorderBrush}" StrokeThickness="1" StrokeDashArray="2,2"/>
                                    
                                    <Line X1="200" Y1="0" X2="200" Y2="200" Stroke="{ThemeResource CardBorderBrush}" StrokeThickness="1" StrokeDashArray="2,2"/>
                                    <Line X1="400" Y1="0" X2="400" Y2="200" Stroke="{ThemeResource CardBorderBrush}" StrokeThickness="1" StrokeDashArray="2,2"/>
                                    <Line X1="600" Y1="0" X2="600" Y2="200" Stroke="{ThemeResource CardBorderBrush}" StrokeThickness="1" StrokeDashArray="2,2"/>

                                    <!-- Eğri Çizgisi -->
                                    <Polyline x:Name="FanCurveLine" Stroke="#10B981" StrokeThickness="3" />

                                    <!-- Kontrol Noktaları Code-Behind üzerinden eklenecek -->
                                </Canvas>
                            </Grid>
                        </Border>

                        <!-- Uygula Butonu -->
                        <Button x:Name="ApplyCurveButton" 
                                Content="Eğriyi Uygula" 
                                Click="ApplyCurveButton_Click"
                                HorizontalAlignment="Center" 
                                Margin="0,16,0,0" 
                                Padding="24,10"
                                FontWeight="SemiBold"
                                Background="#10B981" 
                                Foreground="White" 
                                CornerRadius="8"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

