<Page
    x:Class="OmenFlow_App.Pages.LightingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Background="#070709" Padding="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="LIGHTING STUDIO" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>
                <TextBlock Text="Cihazınızın klavye arka plan aydınlatmasını ve dinamik efektlerini yapılandırın." FontSize="12" Foreground="#8F8F98" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="24">
                
                <!-- Keyboard Display Area Card -->
                <Border Background="#0E0E10" BorderBrush="#1C1C20" BorderThickness="1" CornerRadius="10" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Keyboard Display Area with Viewbox -->
                        <Viewbox Grid.Row="0" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,24" MaxWidth="800" MaxHeight="250">
                            <Grid>
                                <!-- Glow effect -->
                                <Grid x:Name="BackgroundGlowGrid" Margin="-20">
                                    <!-- Single Zone -->
                                    <Border x:Name="SingleZoneGlow" Visibility="Collapsed" CornerRadius="30">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop x:Name="SzStop1" Color="#2010B981" Offset="0.0"/>
                                                <GradientStop x:Name="SzStop2" Color="#7010B981" Offset="0.5"/>
                                                <GradientStop x:Name="SzStop3" Color="#0010B981" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- Multi Zone -->
                                    <Grid x:Name="MultiZoneGlow" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" CornerRadius="30,0,0,30">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop x:Name="Mz0Stop1" Color="#20EF4444" Offset="0.0"/>
                                                    <GradientStop x:Name="Mz0Stop2" Color="#70EF4444" Offset="0.5"/>
                                                    <GradientStop x:Name="Mz0Stop3" Color="#00EF4444" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Border Grid.Column="1">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop x:Name="Mz1Stop1" Color="#20EAB308" Offset="0.0"/>
                                                    <GradientStop x:Name="Mz1Stop2" Color="#70EAB308" Offset="0.5"/>
                                                    <GradientStop x:Name="Mz1Stop3" Color="#00EAB308" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Border Grid.Column="2">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop x:Name="Mz2Stop1" Color="#2010B981" Offset="0.0"/>
                                                    <GradientStop x:Name="Mz2Stop2" Color="#7010B981" Offset="0.5"/>
                                                    <GradientStop x:Name="Mz2Stop3" Color="#0010B981" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Border Grid.Column="3" CornerRadius="0,30,30,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop x:Name="Mz3Stop1" Color="#203B82F6" Offset="0.0"/>
                                                    <GradientStop x:Name="Mz3Stop2" Color="#703B82F6" Offset="0.5"/>
                                                    <GradientStop x:Name="Mz3Stop3" Color="#003B82F6" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Actual Keyboard Image -->
                                <Image Source="ms-appx:///icons/keyboard.png" Stretch="Fill"/>

                                <!-- Clickable Overlays -->
                                <Grid x:Name="ZoneClickOverlay" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- These borders act as buttons and selection indicators -->
                                    <Border x:Name="Zone0Overlay" Grid.Column="0" Background="#01000000" BorderBrush="{ThemeResource PrimaryTextBrush}" BorderThickness="2" CornerRadius="12,0,0,12" Tapped="Zone_Tapped" Tag="0" Margin="4,4,2,4"/>
                                    <Border x:Name="Zone1Overlay" Grid.Column="1" Background="#01000000" BorderBrush="Transparent" BorderThickness="2" Tapped="Zone_Tapped" Tag="1" Margin="2,4,2,4"/>
                                    <Border x:Name="Zone2Overlay" Grid.Column="2" Background="#01000000" BorderBrush="Transparent" BorderThickness="2" Tapped="Zone_Tapped" Tag="2" Margin="2,4,2,4"/>
                                    <Border x:Name="Zone3Overlay" Grid.Column="3" Background="#01000000" BorderBrush="Transparent" BorderThickness="2" CornerRadius="0,12,12,0" Tapped="Zone_Tapped" Tag="3" Margin="2,4,4,4"/>
                                </Grid>
                            </Grid>
                        </Viewbox>
                        
                        <TextBlock Grid.Row="1" x:Name="SelectedZoneText" Text="Seçili Bölge: 1 (Sol)" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Config & Color Controls Grid -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column Controls: Effect, Brightness, Speed -->
                    <Border Grid.Column="0" Background="#0E0E10" BorderBrush="#1C1C20" BorderThickness="1" CornerRadius="10" Padding="18">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE765;" FontSize="15" Foreground="#8B5CF6"/>
                                <TextBlock Text="Efekt &amp; Hız Ayarları" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF"/>
                            </StackPanel>

                            <!-- Effect ComboBox -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Aydınlatma Efekti" FontSize="11" Foreground="#9CA3AF"/>
                                <ComboBox x:Name="EffectComboBox" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="EffectComboBox_SelectionChanged" Background="#151518" BorderBrush="#2F2F35" Foreground="#FFFFFF">
                                    <ComboBoxItem Content="Statik (Sabit)"/>
                                    <ComboBoxItem Content="Nefes Alma (Breathing)"/>
                                    <ComboBoxItem Content="Renk Döngüsü (Color Cycle)"/>
                                    <ComboBoxItem Content="Dalga (Wave)"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Brightness Slider -->
                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="Klavye Parlaklığı" FontSize="11" Foreground="#9CA3AF"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ElementName=BrightnessSlider, Path=Value}" FontSize="11" Foreground="#8B5CF6"/>
                                        <TextBlock Text="%" FontSize="11" Foreground="#8B5CF6"/>
                                    </StackPanel>
                                </Grid>
                                <Slider x:Name="BrightnessSlider" Minimum="0" Maximum="100" Value="100" StepFrequency="10" ValueChanged="BrightnessSlider_ValueChanged"/>
                            </StackPanel>

                            <!-- Speed Slider -->
                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="Efekt Hızı" FontSize="11" Foreground="#9CA3AF"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ElementName=SpeedSlider, Path=Value}" FontSize="11" Foreground="#8B5CF6"/>
                                        <TextBlock Text="%" FontSize="11" Foreground="#8B5CF6"/>
                                    </StackPanel>
                                </Grid>
                                <Slider x:Name="SpeedSlider" Minimum="1" Maximum="100" Value="50" StepFrequency="5" ValueChanged="SpeedSlider_ValueChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Right Column Controls: Color Selection -->
                    <Border Grid.Column="1" Background="#0E0E10" BorderBrush="#1C1C20" BorderThickness="1" CornerRadius="10" Padding="18">
                        <StackPanel Spacing="16" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE790;" FontSize="15" Foreground="#FF00A2"/>
                                <TextBlock Text="Renk Seçimi" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF"/>
                            </StackPanel>

                            <TextBlock Text="Bölge veya klavye geneli için hazır bir renk atayın ya da özel renk seçin." FontSize="11" Foreground="#7C7C82" Margin="0,0,0,8"/>

                            <!-- Presets Grid -->
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,4,0,16">
                                <Button Width="36" Height="36" CornerRadius="18" BorderThickness="1.5" BorderBrush="#2F2F35" Background="#FF0000" Click="PresetColor_Click"/>
                                <Button Width="36" Height="36" CornerRadius="18" BorderThickness="1.5" BorderBrush="#2F2F35" Background="#FFFF00" Click="PresetColor_Click"/>
                                <Button Width="36" Height="36" CornerRadius="18" BorderThickness="1.5" BorderBrush="#2F2F35" Background="#00FF00" Click="PresetColor_Click"/>
                                <Button Width="36" Height="36" CornerRadius="18" BorderThickness="1.5" BorderBrush="#2F2F35" Background="#0000FF" Click="PresetColor_Click"/>
                                <Button Width="36" Height="36" CornerRadius="18" BorderThickness="1.5" BorderBrush="#2F2F35" Background="#FF00FF" Click="PresetColor_Click"/>
                                <Button Width="36" Height="36" CornerRadius="18" BorderThickness="1.5" BorderBrush="#2F2F35" Background="#FFFFFF" Click="PresetColor_Click"/>
                                
                                <!-- Custom Color Picker Button -->
                                <Button Width="36" Height="36" CornerRadius="18" BorderThickness="1.5" BorderBrush="#2F2F35" Padding="0" ToolTipService.ToolTip="Özel Renk">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF0000" Offset="0.0"/>
                                            <GradientStop Color="#FFFF00" Offset="0.33"/>
                                            <GradientStop Color="#00FF00" Offset="0.66"/>
                                            <GradientStop Color="#0000FF" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <Button.Flyout>
                                        <Flyout>
                                            <StackPanel Spacing="12" Background="#111113" Padding="12" CornerRadius="8">
                                                <TextBlock Text="Özel Renk Seç" FontWeight="Bold" Foreground="#FFFFFF"/>
                                                <ColorPicker x:Name="ZoneColorPicker" IsMoreButtonVisible="True" IsColorSliderVisible="True" IsColorChannelTextInputVisible="True" IsHexInputVisible="True" IsAlphaEnabled="False" ColorChanged="ZoneColorPicker_ColorChanged" Height="300" Foreground="#FFFFFF"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                            
                            <Border BorderBrush="#1C1C20" BorderThickness="1" CornerRadius="6" Padding="10" Background="#151518">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Path Data="M 12,2 L 22,12 L 12,22 L 2,12 Z" Fill="#FF00A2" Height="14" Width="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="OMEN RGB denetleyicisi algılandı." FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
