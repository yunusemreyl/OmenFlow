<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OmenFlow_App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmenFlow_App"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4F6F8"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1F2937"/>
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#374151"/>
                    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#6B7280"/>
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E7EB"/>
                    <SolidColorBrush x:Key="CardAltBackgroundBrush" Color="#F9FAFB"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0CFFFFFF"/>
                    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F9FAFB"/>
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#E5E7EB"/>
                    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#15FFFFFF"/>
                    <SolidColorBrush x:Key="CardAltBackgroundBrush" Color="#05FFFFFF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0CFFFFFF"/>
                    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F9FAFB"/>
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#E5E7EB"/>
                    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#15FFFFFF"/>
                    <SolidColorBrush x:Key="CardAltBackgroundBrush" Color="#05FFFFFF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            
            <Style x:Key="ShadowCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="24"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="12"/>
            </Style>

            <Style x:Key="GridBoxStyle" TargetType="ToggleButton">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="Margin" Value="4"/>
            </Style>

            <Style x:Key="HorizontalBarBoxStyle" TargetType="ToggleButton">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Padding" Value="16,0,16,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style x:Key="MiniCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="0,8,0,0"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
