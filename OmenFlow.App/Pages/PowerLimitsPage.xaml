<Page
    x:Class="OmenFlow_App.Pages.PowerLimitsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Background="{ThemeResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Güç Limitleri Yönetimi" Visibility="Collapsed" FontSize="22" FontWeight="SemiBold" Margin="20,16,0,16" Foreground="{ThemeResource PrimaryTextBrush}"/>

        <ScrollViewer Grid.Row="1" Margin="16,12,16,20" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">
                
                <!-- 1. Real-Time Telemetry Card -->
                <StackPanel Spacing="8">
                    <Grid Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14" Foreground="#D97706"/>
                            <TextBlock Text="Anlık Güç Tüketimleri" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Grid>
                    
                    <Border Style="{StaticResource ShadowCardStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- CPU Telemetry -->
                            <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="CPU Tüketim &amp; Sıcaklık" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CpuPowerText" Text="-- W" FontSize="22" FontWeight="Bold" Foreground="#D97706" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CpuTempText" Text="-- °C" FontSize="12" FontWeight="SemiBold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- GPU Telemetry -->
                            <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="GPU Tüketim &amp; Sıcaklık" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="GpuPowerText" Text="-- W" FontSize="22" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="GpuTempText" Text="-- °C" FontSize="12" FontWeight="SemiBold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <Border Height="1" Background="{ThemeResource CardBorderBrush}"/>

                <!-- 2. Power Limit Controls Card -->
                <StackPanel Spacing="8">
                    <Grid Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7AD;" FontSize="14" Foreground="#2563EB"/>
                            <TextBlock Text="Donanımsal Limit Ayarları" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource ShadowCardStyle}" Padding="16">
                        <StackPanel Spacing="16">
                            <!-- CPU PL1 -->
                            <StackPanel Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CPU PL1 (Sürekli Güç Limiti)" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TextCpuPl1Value" Text="45 W" Grid.Column="1" FontWeight="SemiBold"/>
                                </Grid>
                                <TextBlock Text="İşlemcinin sürekli olarak çekebileceği maksimum güç." Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                                <Slider x:Name="SliderCpuPl1" Minimum="15" Maximum="115" Value="45" TickFrequency="5" SnapsTo="Ticks" Header="" ValueChanged="Slider_ValueChanged"/>
                            </StackPanel>

                            <!-- CPU PL2 -->
                            <StackPanel Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CPU PL2 (Kısa Süreli Boost Güç Limiti)" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TextCpuPl2Value" Text="90 W" Grid.Column="1" FontWeight="SemiBold"/>
                                </Grid>
                                <TextBlock Text="İşlemcinin anlık aşırı yüklerde çekebileceği maksimum boost gücü." Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                                <Slider x:Name="SliderCpuPl2" Minimum="15" Maximum="140" Value="90" TickFrequency="5" SnapsTo="Ticks" Header="" ValueChanged="Slider_ValueChanged"/>
                            </StackPanel>

                            <Border Height="1" Background="{ThemeResource CardBorderBrush}"/>

                            <!-- GPU TGP -->
                            <StackPanel Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="GPU TGP (Ekran Kartı Güç Limiti)" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TextGpuTgpValue" Text="80 W" Grid.Column="1" FontWeight="SemiBold"/>
                                </Grid>
                                <TextBlock Text="Ekran kartına tahsis edilecek maksimum hedef güç." Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                                <Slider x:Name="SliderGpuTgp" Minimum="30" Maximum="150" Value="80" TickFrequency="5" SnapsTo="Ticks" Header="" ValueChanged="Slider_ValueChanged"/>
                            </StackPanel>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⚠️ Limitleri aşırı yüksek ayarlamak yüksek sıcaklıklara yol açabilir." VerticalAlignment="Center" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,12,0"/>
                                <Button x:Name="BtnApplyPowerLimits" Content="Limitleri Uygula" Grid.Column="1" Click="BtnApplyPowerLimits_Click" Style="{StaticResource AccentButtonStyle}" Width="160"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
