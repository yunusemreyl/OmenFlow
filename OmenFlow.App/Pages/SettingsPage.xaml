<Page
    x:Class="OmenFlow_App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OmenFlow_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Background="{ThemeResource OmenAppBackgroundBrush}" Padding="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock x:Uid="SettingsPage_Header" Text="GENEL AYARLAR" FontSize="20" FontWeight="Bold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                <TextBlock x:Uid="SettingsPage_HeaderDesc" Text="Uygulama başlangıç, görünüm teması ve acil durum koruma sınırlarını yapılandırın." FontSize="12" Foreground="{ThemeResource OmenTertiaryTextBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
        
        <!-- Scrollable settings list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="20" MaxWidth="900" HorizontalAlignment="Left">
                
                <!-- Card 1: Başlangıç & Görünüm Ayarları -->
                <Border Background="{ThemeResource OmenCardBackgroundDarkBrush}" BorderBrush="{ThemeResource OmenCardBorderDarkBrush}" BorderThickness="1" CornerRadius="10" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7F4;" FontSize="15" Foreground="#3B82F6"/>
                            <TextBlock x:Uid="SettingsPage_Card1Title" Text="Sistem &amp; Görünüm" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                        </StackPanel>

                        <!-- Başlangıçta Çalıştırma -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Uid="SettingsPage_StartupTitle" Text="Başlangıçta Çalıştırma" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="SettingsPage_StartupDesc" Text="Bilgisayar açıldığında uygulamanın nasıl başlayacağını seçin." Foreground="{ThemeResource OmenTertiaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ComboBox x:Name="ComboStartupMode" Grid.Column="1" Width="160" VerticalAlignment="Center" SelectionChanged="ComboStartupMode_SelectionChanged" Background="{ThemeResource OmenCardBackgroundElevatedBrush}" BorderBrush="{ThemeResource OmenCardBorderElevatedBrush}" Foreground="{ThemeResource OmenPrimaryTextBrush}">
                                <ComboBoxItem x:Uid="SettingsPage_Startup_OpenUI" Content="Arayüzü Aç" Tag="OpenUI"/>
                                <ComboBoxItem x:Uid="SettingsPage_Startup_Tray" Content="Tray Olarak Başlat" Tag="Tray"/>
                                <ComboBoxItem x:Uid="SettingsPage_Startup_Disabled" Content="Başlatma" Tag="Disabled"/>
                            </ComboBox>
                        </Grid>

                        <Border Height="1" Background="{ThemeResource OmenCardBorderDarkBrush}" Margin="0,4,0,4"/>

                        <!-- Uygulama Teması -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Uid="SettingsPage_ThemeTitle" Text="Uygulama Teması" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="SettingsPage_ThemeDesc" Text="Uygulamanın renk temasını değiştirin (Dark önerilir)." Foreground="{ThemeResource OmenTertiaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ComboBox x:Name="ComboTheme" Grid.Column="1" Width="160" VerticalAlignment="Center" SelectionChanged="ComboTheme_SelectionChanged" Background="{ThemeResource OmenCardBackgroundElevatedBrush}" BorderBrush="{ThemeResource OmenCardBorderElevatedBrush}" Foreground="{ThemeResource OmenPrimaryTextBrush}">
                                <ComboBoxItem x:Uid="SettingsPage_Theme_System" Content="Sistem Varsayılanı" Tag="System"/>
                                <ComboBoxItem x:Uid="SettingsPage_Theme_Light" Content="Açık Tema" Tag="Light"/>
                                <ComboBoxItem x:Uid="SettingsPage_Theme_Dark" Content="Koyu Tema" Tag="Dark"/>
                            </ComboBox>
                        </Grid>

                        <Border Height="1" Background="{ThemeResource OmenCardBorderDarkBrush}" Margin="0,4,0,4"/>

                        <!-- Dil Seçeneği -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Uid="SettingsPage_LanguageTitle" Text="Dil Seçeneği" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="SettingsPage_LanguageDesc" Text="Uygulama arayüz dilini değiştirin." Foreground="{ThemeResource OmenTertiaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ComboBox x:Name="ComboLanguage" Grid.Column="1" Width="160" VerticalAlignment="Center" SelectionChanged="ComboLanguage_SelectionChanged" Background="{ThemeResource OmenCardBackgroundElevatedBrush}" BorderBrush="{ThemeResource OmenCardBorderElevatedBrush}" Foreground="{ThemeResource OmenPrimaryTextBrush}">
                                <ComboBoxItem Content="Türkçe" Tag="tr-TR"/>
                                <ComboBoxItem Content="English" Tag="en-US"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Card 2: Güvenlik ve Koruma Ayarları -->
                <Border Background="{ThemeResource OmenCardBackgroundDarkBrush}" BorderBrush="{ThemeResource OmenCardBorderDarkBrush}" BorderThickness="1" CornerRadius="10" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7BA;" FontSize="15" Foreground="#FF3B30"/>
                            <TextBlock x:Uid="SettingsPage_Card2Title" Text="Güvenlik ve Aşırı Isınma Koruması" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                        </StackPanel>
                        
                        <!-- Acil Durum Max Fan -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock x:Uid="SettingsPage_MaxFanTitle" Text="Acil Durum Max Fan Koruması" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="SettingsPage_MaxFanDesc" Text="Sıcaklık 95°C'ye ulaştığında fanları koruma amacıyla otomatik olarak maksimum devire çıkarır." Foreground="{ThemeResource OmenTertiaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ToggleThermalSafety" Grid.Column="1" VerticalAlignment="Center" Toggled="ToggleThermalSafety_Toggled"/>
                        </Grid>

                        <Border Height="1" Background="{ThemeResource OmenCardBorderDarkBrush}" Margin="0,4,0,4"/>

                        <!-- Quiet Safety -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock x:Uid="SettingsPage_QuietSafetyTitle" Text="Sessiz Mod Isınma Koruması (Quiet Safety)" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="SettingsPage_QuietSafetyDesc" Text="Quiet moddayken CPU sıcaklığı 93°C'yi aştığında (8 saniye boyunca) profili otomatik olarak Dengeli moda yükseltir." Foreground="{ThemeResource OmenTertiaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ToggleQuietSafety" Grid.Column="1" VerticalAlignment="Center" Toggled="ToggleQuietSafety_Toggled"/>
                        </Grid>

                        <Border BorderBrush="{ThemeResource OmenCardBorderDarkBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{ThemeResource OmenCardBackgroundPressedBrush}" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#D97706"/>
                                <TextBlock x:Uid="SettingsPage_WarningText" Text="⚠️ DİKKAT: Güvenlik korumalarını kapatmak, termal throttle veya aşırı ısınmaya sebep olabilir." FontSize="11" Foreground="#F43F5E" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Card 3: Tanılama Raporu -->
                <Border Background="{ThemeResource OmenCardBackgroundDarkBrush}" BorderBrush="{ThemeResource OmenCardBorderDarkBrush}" BorderThickness="1" CornerRadius="10" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D9;" FontSize="15" Foreground="#10B981"/>
                            <TextBlock x:Uid="SettingsPage_Card3Title" Text="Tanılama ve Raporlama" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock x:Uid="SettingsPage_ExportTitle" Text="Tanılama Raporu Paketle (ZIP)" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="SettingsPage_ExportDesc" Text="Fan geçmişi, EC durum verileri ve donanım bilgilerini Masaüstünüze ZIP olarak kaydeder." Foreground="{ThemeResource OmenTertiaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button x:Name="BtnExportDiagnostics" x:Uid="SettingsPage_BtnExport" Content="ZIP Raporu Üret" Grid.Column="1" VerticalAlignment="Center" Click="BtnExportDiagnostics_Click" Style="{StaticResource AccentButtonStyle}" Background="#2563EB" BorderBrush="#3B82F6" Foreground="#FFFFFF"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Card 4: Hakkında -->
                <Border Background="{ThemeResource OmenCardBackgroundDarkBrush}" BorderBrush="{ThemeResource OmenCardBorderDarkBrush}" BorderThickness="1" CornerRadius="10" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Data="M 12,2 L 22,12 L 12,22 L 2,12 Z" Fill="#E00078" Height="14" Width="14" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock x:Uid="SettingsPage_Card4Title" Text="Hakkında" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                        </StackPanel>
                        
                        <TextBlock x:Uid="SettingsPage_About1" Text="OmenFlow, HP cihazlarını yönetmek için geliştirilmiş açık kaynaklı bağımsız bir uygulamadır." Foreground="{ThemeResource OmenSecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                        <TextBlock x:Uid="SettingsPage_About2" Text="⚠️ HP Inc. ile hiçbir resmi bağı yoktur ve HP tarafından yapılmamıştır." Foreground="#D97706" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap"/>
                        
                        <HyperlinkButton x:Uid="SettingsPage_AboutLink" Content="GitHub Hesabı ve Kaynak Kod" NavigateUri="https://github.com/yeyil" Padding="0" Margin="0,4,0,0" Foreground="#3B82F6"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
