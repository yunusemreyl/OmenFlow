<Page
    x:Class="OmenFlow_App.Pages.AdditionalSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24,16,24,16" RowSpacing="24" Background="{ThemeResource OmenAppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <TextBlock x:Uid="Additional_Header" Text="Ek Ayarlar" FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}" Margin="12,0,0,16" />
        
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16" MaxWidth="800" HorizontalAlignment="Left">
                
                <!-- Güç ve Pil Ayarları -->
                <Border Style="{StaticResource ShadowCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="Additional_PowerBattery" Text="Güç ve Pil" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Uid="Additional_BatteryCare" Text="Pil Koruma (Adaptive Battery Optimizer)" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="Additional_BatteryCareDesc" Text="Pil sağlığını korumak için şarj seviyesini %80'de sınırlar." Foreground="{ThemeResource OmenSecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ToggleBatteryCare" Grid.Column="1" Toggled="ToggleBatteryCare_Toggled"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Uid="Additional_USBCharging" Text="Her Zaman Açık USB (USB Charging)" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="Additional_USBChargingDesc" Text="Cihaz uykudayken veya kapalıyken USB portlarından güç vermeye devam eder." Foreground="{ThemeResource OmenSecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ToggleUsbCharging" Grid.Column="1" Toggled="ToggleUsbCharging_Toggled"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- Güç Modu Otomasyonu -->
                <Border Style="{StaticResource ShadowCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="Additional_PowerAutomation" Text="Güç Modu Otomasyonu" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Uid="Additional_AutoProfile" Text="Otomatik Profil Değişimi" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="Additional_AutoProfileDesc" Text="Şarj cihazı takıldığında veya çıkarıldığında performans profilini otomatik olarak değiştirir." Foreground="{ThemeResource OmenSecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="TogglePowerAutomation" Grid.Column="1" Toggled="TogglePowerAutomation_Toggled"/>
                        </Grid>

                        <StackPanel x:Name="PanelAutomationSettings" Spacing="12" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Uid="Additional_ACProfile" Text="Şarja Takılıyken Uygulanacak Profil" VerticalAlignment="Center" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <ComboBox x:Name="ComboAcProfile" Grid.Column="1" Width="160" SelectionChanged="AutomationProfile_SelectionChanged" Background="{ThemeResource OmenCardBackgroundElevatedBrush}" BorderBrush="{ThemeResource OmenCardBorderElevatedBrush}" Foreground="{ThemeResource OmenPrimaryTextBrush}">
                                    <ComboBoxItem x:Uid="Additional_ProfileQuiet" Content="Sessiz Mod" Tag="Quiet"/>
                                    <ComboBoxItem x:Uid="Additional_ProfileDefault" Content="Dengeli Mod" Tag="Default"/>
                                    <ComboBoxItem x:Uid="Additional_ProfilePerformance" Content="Performans Modu" Tag="Performance"/>
                                </ComboBox>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Uid="Additional_BatProfile" Text="Bataryadayken Uygulanacak Profil" VerticalAlignment="Center" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <ComboBox x:Name="ComboBatProfile" Grid.Column="1" Width="160" SelectionChanged="AutomationProfile_SelectionChanged" Background="{ThemeResource OmenCardBackgroundElevatedBrush}" BorderBrush="{ThemeResource OmenCardBorderElevatedBrush}" Foreground="{ThemeResource OmenPrimaryTextBrush}">
                                    <ComboBoxItem x:Uid="Additional_ProfileQuiet" Content="Sessiz Mod" Tag="Quiet"/>
                                    <ComboBoxItem x:Uid="Additional_ProfileDefault" Content="Dengeli Mod" Tag="Default"/>
                                    <ComboBoxItem x:Uid="Additional_ProfilePerformance" Content="Performans Modu" Tag="Performance"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Border Style="{StaticResource ShadowCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="Additional_HardwareLock" Text="Donanım Kilidi" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Uid="Additional_WinKeyLock" Text="Windows Tuşu Kilidi" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="Additional_WinKeyLockDesc" Text="Oyun sırasında yanlışlıkla Başlat menüsünün açılmasını engeller." Foreground="{ThemeResource OmenSecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ToggleWinKeyLock" Grid.Column="1" Toggled="ToggleWinKeyLock_Toggled"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Uid="Additional_TouchpadLock" Text="Dokunmatik Yüzey (Touchpad) Kilidi" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock x:Uid="Additional_TouchpadLockDesc" Text="Yazı yazarken veya oyun oynarken touchpad'i tamamen devre dışı bırakır." Foreground="{ThemeResource OmenSecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ToggleTouchpadLock" Grid.Column="1" Toggled="ToggleTouchpadLock_Toggled"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Oyun & Uygulama Otomasyonu (Auto Profiles) -->
                <Border Style="{StaticResource ShadowCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Game and App Detection (Auto Profiles)" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Automatic Game Profile" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock Text="Automatically switches to Performance mode when one of the games/apps below is launched, and reverts to the previous mode when closed." Foreground="{ThemeResource OmenSecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ToggleAutoProfileGames" Grid.Column="1" Toggled="ToggleAutoProfileGames_Toggled"/>
                        </Grid>

                        <StackPanel x:Name="PanelAutoProfileGames" Spacing="8" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtNewGame" PlaceholderText="Game exe name (e.g. cs2.exe)" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button x:Name="BtnAddGame" Grid.Column="1" Content="Add" Click="BtnAddGame_Click"/>
                            </Grid>

                            <ListView x:Name="ListGames" Margin="0,8,0,0" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="8,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                            <Button Grid.Column="1" Content="Remove" Tag="{Binding}" Click="BtnRemoveGame_Click" Background="Transparent" BorderThickness="0" Foreground="Red"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- OMEN Tuşu Devralma -->
                <Border Style="{StaticResource ShadowCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Shortcuts and System" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Intercept OMEN Key" FontWeight="SemiBold" Foreground="{ThemeResource OmenPrimaryTextBrush}"/>
                                <TextBlock Text="Directly launches OmenFlow instead of OMEN Gaming Hub when the dedicated OMEN logo key is pressed (Uses Registry Redirection)." Foreground="{ThemeResource OmenSecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ToggleOmenKey" Grid.Column="1" Toggled="ToggleOmenKey_Toggled"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
