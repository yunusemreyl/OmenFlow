<Page
    x:Class="OmenFlow_App.Pages.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Background="{ThemeResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Performans Kontrolü" Visibility="Collapsed" FontSize="22" FontWeight="SemiBold" Margin="20,16,0,16" Foreground="{ThemeResource PrimaryTextBrush}"/>

        <ScrollViewer Grid.Row="1" Margin="16,12,16,20" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">
                
                <!-- 1. Performans Profili & CPU Durumu -->
                <StackPanel Spacing="8">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7A6;" FontSize="14" Foreground="#2563EB"/>
                            <TextBlock Text="Performans Profili" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" VerticalAlignment="Center">
                            <TextBlock x:Name="CpuTempText" Text="45°C" FontSize="11" FontWeight="Bold" Foreground="#DC2626"/>
                            <TextBlock Text="•" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}"/>
                            <TextBlock x:Name="CpuFanText" Text="2400 RPM" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <TextBlock Text="•" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}"/>
                            <TextBlock x:Name="CpuPowerText" Text="15.2 W" FontSize="11" FontWeight="Bold" Foreground="#D97706"/>
                            <TextBlock x:Name="CpuUsageText" Text="%12" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <Grid Height="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton x:Name="BtnPerfQuiet" Grid.Column="0" Style="{StaticResource GridBoxStyle}" Click="PerfMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE7ED;" FontSize="18" Foreground="#10B981"/>
                                <TextBlock Text="Düşük Gürültü" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="BtnPerfDefault" Grid.Column="1" Style="{StaticResource GridBoxStyle}" IsChecked="True" Click="PerfMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE799;" FontSize="18" Foreground="#2563EB"/>
                                <TextBlock Text="Dengeli" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="BtnPerfPerf" Grid.Column="2" Style="{StaticResource GridBoxStyle}" Click="PerfMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE945;" FontSize="18" Foreground="#DC2626"/>
                                <TextBlock Text="Maksimum" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                    </Grid>
                </StackPanel>

                <Border Height="1" Background="{ThemeResource CardBorderBrush}"/>

                <!-- 2. Fan Yönetim Modu -->
                <StackPanel Spacing="8">
                    <Grid Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9CA;" FontSize="14" Foreground="#2563EB"/>
                            <TextBlock Text="Fan Yönetim Modu" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Height="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton x:Name="BtnFanAuto" Grid.Column="0" Style="{StaticResource GridBoxStyle}" IsChecked="True" Click="FanMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE9A1;" FontSize="18" Foreground="#2563EB"/>
                                <TextBlock Text="Auto BIOS" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="BtnFanOmenFlow" Grid.Column="1" Style="{StaticResource GridBoxStyle}" Click="FanMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE81E;" FontSize="18" Foreground="#10B981"/>
                                <TextBlock Text="OmenFlow" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="BtnFanMax" Grid.Column="2" Style="{StaticResource GridBoxStyle}" Click="FanMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE9CA;" FontSize="18" Foreground="#D97706"/>
                                <TextBlock Text="Max Fan" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="BtnFanManual" Grid.Column="3" Style="{StaticResource GridBoxStyle}" Click="FanMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE790;" FontSize="18" Foreground="{ThemeResource TertiaryTextBrush}"/>
                                <TextBlock Text="Custom" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                    </Grid>
                </StackPanel>

                <Border Height="1" Background="{ThemeResource CardBorderBrush}"/>

                <!-- 3. GPU MUX Anahtarı & GPU Durumu -->
                <StackPanel Spacing="8">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14" Foreground="#10B981"/>
                            <TextBlock Text="GPU MUX Anahtarı" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" VerticalAlignment="Center">
                            <TextBlock x:Name="GpuTempText" Text="38°C" FontSize="11" FontWeight="Bold" Foreground="#DC2626"/>
                            <TextBlock Text="•" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}"/>
                            <TextBlock x:Name="GpuFanText" Text="0 RPM" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <TextBlock Text="•" FontSize="11" Foreground="{ThemeResource TertiaryTextBrush}"/>
                            <TextBlock x:Name="GpuPowerText" Text="8.4 W" FontSize="11" FontWeight="Bold" Foreground="#D97706"/>
                            <TextBlock x:Name="GpuUsageText" Text="%4" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <Grid Height="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton x:Name="BtnMuxHybrid" Grid.Column="0" Style="{StaticResource GridBoxStyle}" IsChecked="True" Click="MuxMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE9D9;" FontSize="18" Foreground="#10B981"/>
                                <TextBlock Text="Hybrid" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="BtnMuxDiscrete" Grid.Column="1" Style="{StaticResource GridBoxStyle}" Click="MuxMode_Click">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE7F4;" FontSize="18" Foreground="#DC2626"/>
                                <TextBlock Text="Discrete" HorizontalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </ToggleButton>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

